<mxfile host="app.diagrams.net">
  <diagram name="Architecture Homelab SISR" id="homelab-archi">
    <mxGraphModel dx="1200" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Internet -->
        <mxCell id="internet" value="INTERNET" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="480" y="40" width="140" height="50" as="geometry" />
        </mxCell>

        <!-- pfSense -->
        <mxCell id="pfsense" value="pfSense&#10;Firewall / Routeur / VPN" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="460" y="150" width="180" height="60" as="geometry" />
        </mxCell>

        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="internet" target="pfsense">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Zone LAN interne -->
        <mxCell id="zoneLAN" value="LAN INTERNE — 192.168.10.0/24" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=none;strokeColor=#82b366;dashed=1;fontSize=13;fontStyle=1;fontColor=#82b366;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="80" y="280" width="280" height="420" as="geometry" />
