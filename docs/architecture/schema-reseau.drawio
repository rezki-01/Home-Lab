        <mxCell id="dc01" value="DC01 — Windows Server 2022&#10;AD DS / DNS / DHCP / GPO&#10;192.168.10.10" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12" vertex="1" parent="1">
